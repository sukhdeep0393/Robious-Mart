// ---- LOGS ----
async function loadLogs(){
  const filt=document.getElementById('logFilt')?.value||'all',df=document.getElementById('logDate')?.value||'';
  const el=document.getElementById('logsList');if(!el)return;
  el.innerHTML='<div class="empty"><div class="ei">⏳</div>Loading...</div>';
  try{
    const cols=filt==='all'?['dailyReports','fuelReports','scratchCounts','invoices']:[filt];
    let all=[];
    for(const col of cols){const snap=await window.F.getDocs(window.F.query(window.F.collection(window.db,col),window.F.orderBy('timestamp','desc'),window.F.limit(25)));snap.docs.forEach(d=>all.push({id:d.id,col,...d.data()}));}
    if(df)all=all.filter(d=>d.date===df);
    all.sort((a,b)=>(b.timestamp?.seconds||0)-(a.timestamp?.seconds||0));
    if(!all.length){el.innerHTML='<div class="empty"><div class="ei">📊</div>No entries found</div>';return;}
    el.innerHTML=all.slice(0,40).map(d=>{
      let t='',det='',b='';
      if(d.col==='dailyReports'){
        const cs=d.cashStatus==='short'?` · <span style="color:var(--red)">Short $${Math.abs(d.cashDifference||0).toFixed(2)}</span>`:d.cashStatus==='over'?` · <span style="color:var(--green)">Over $${Math.abs(d.cashDifference||0).toFixed(2)}</span>`:'';
        t=`${d.shift} shift — ${d.employee}`;det=`Sales: $${(d.totalSales||0).toFixed(2)} · Fuel: ${((d.regularGal||0)+(d.premiumGal||0)+(d.dieselGal||0)).toFixed(0)} gal${cs}`;b='<span class="badge bblu">Daily</span>';
      }
      else if(d.col==='fuelReports'){t=`Fuel — ${d.employee}`;det=`Reg: ${d.regularGal||0} · Prem: ${d.premiumGal||0} · Diesel: ${d.dieselGal||0} gal`;b='<span class="badge bgrn">Fuel</span>';}
      else if(d.col==='scratchCounts'){t=`${d.shiftType==='start'?'Opening':'Closing'} count — ${d.employee}`;det=`Est. value: $${(d.totalValue||0).toLocaleString()}`;b='<span class="badge bamb">Scratch</span>';}
      else if(d.col==='invoices'){t=d.fileName||'Invoice';det=`By ${d.employee||'Unknown'} — ${(d.analysis||'').substring(0,70)}...`;b='<span class="badge bred">Invoice</span>';}
      return`<div class="litem"><div class="ltitle">${b}<span style="margin-left:6px">${t}</span></div><div class="lmeta">${d.date||''}</div><div class="ldet">${det}</div></div>`;
    }).join('');
  }catch(e){el.innerHTML='<div class="empty">Error loading.</div>';}
}


// ---- EMPLOYEES TAB (operator) ----
async function loadEmployees(){
  const el=document.getElementById('empContent');
  const photoEl=document.getElementById('fuelPhotoList');
  if(!el)return;
  el.innerHTML='<div class="empty"><div class="ei">⏳</div>Loading...</div>';

  const month=document.getElementById('empMonth')?.value||new Date().toISOString().slice(0,7);
  const mtdStart=month+'-01';
  const mtdEnd=month+'-31';
  const filterEmp=document.getElementById('empFilter')?.value||'all';

  try{
    const snap=await window.F.getDocs(window.F.query(window.F.collection(window.db,'dailyReports'),window.F.orderBy('timestamp','desc'),window.F.limit(500)));
    const all=snap.docs.map(d=>({id:d.id,...d.data()})).filter(r=>r.date>=mtdStart&&r.date<=mtdEnd);

    // Build employee map
    const empMap={};
    all.forEach(r=>{
      if(!r.employee)return;
      if(!empMap[r.employee])empMap[r.employee]={name:r.employee,shifts:[],totalHours:0};
      empMap[r.employee].shifts.push(r);
      empMap[r.employee].totalHours+=parseFloat(r.hoursWorked)||0;
    });

    // Populate filter dropdown
    const sel=document.getElementById('empFilter');
    if(sel){
      const existing=Array.from(sel.options).map(o=>o.value);
      Object.keys(empMap).forEach(n=>{if(!existing.includes(n)){const o=document.createElement('option');o.value=n;o.textContent=n;sel.appendChild(o);}});
    }

    const filtered=filterEmp==='all'?Object.values(empMap):Object.values(empMap).filter(e=>e.name===filterEmp);
    if(!filtered.length){el.innerHTML='<div class="empty"><div class="ei">👥</div>No shifts submitted this month</div>';return;}

    el.innerHTML=filtered.map(e=>{
      const shifts=e.shifts.sort((a,b)=>b.date.localeCompare(a.date));
      return`<div class="emp-card">
        <div class="emp-header">
          <div style="display:flex;align-items:center;gap:10px">
            <div class="emp-avatar">${e.name.charAt(0).toUpperCase()}</div>
            <div><div style="font-size:15px;font-weight:600">${e.name}</div><div style="font-size:12px;color:var(--text3)">${e.shifts.length} shift${e.shifts.length!==1?'s':''} this month</div></div>
          </div>
          <div style="text-align:right"><div style="font-size:18px;font-weight:700;color:var(--blue)">${e.totalHours.toFixed(1)}</div><div style="font-size:11px;color:var(--text3)">total hrs</div></div>
        </div>
        <div style="border-top:1px solid var(--border);padding-top:10px">
          ${shifts.map(r=>`<div class="hours-row">
            <div>
              <div style="font-weight:500">${new Date(r.date+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'})}</div>
              <div style="font-size:11px;color:var(--text3)">${r.shift||''} ${r.startTime&&r.endTime?'· '+r.startTime+' – '+r.endTime:''} ${r.shiftComment?'· "'+r.shiftComment+'"':''}</div>
            </div>
            <div style="font-weight:600;color:var(--blue);flex-shrink:0">${r.hoursWorked?r.hoursWorked.toFixed(1)+' hrs':'—'}</div>
          </div>`).join('')}
        </div>
      </div>`;
    }).join('');
  }catch(e){el.innerHTML='<div class="empty">Error loading employee data</div>';}

  // Load fuel photos
  loadFuelPhotos();
}

async function loadFuelPhotos(){
  const el=document.getElementById('fuelPhotoList');
  if(!el)return;
  const dateFilter=document.getElementById('fuelPhotoDate')?.value||'';
  try{
    const snap=await window.F.getDocs(window.F.query(window.F.collection(window.db,'fuelReports'),window.F.orderBy('timestamp','desc'),window.F.limit(60)));
    let docs=snap.docs.map(d=>({id:d.id,...d.data()})).filter(d=>d.photoUrl&&d.photoUrl!='');
    if(dateFilter)docs=docs.filter(d=>d.date===dateFilter);
    if(!docs.length){el.innerHTML='<div class="empty"><div class="ei">📷</div>No fuel photos'+(dateFilter?' for this date':' yet')+'</div>';return;}
    el.innerHTML=docs.map(d=>`<div class="card" style="margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
        <div style="font-size:13px;font-weight:500">${new Date(d.date+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'})}</div>
        <span class="badge bgrn">${d.employee||'Unknown'}</span>
      </div>
      <img src="${d.photoUrl}" class="fuel-photo-thumb" onclick="window.open('${d.photoUrl}','_blank')" alt="Fuel report ${d.date}" />
      <div style="font-size:12px;color:var(--text3);margin-top:6px">Reg: ${d.regularGal||0} · Prem: ${d.premiumGal||0} · Diesel: ${d.dieselGal||0} gal</div>
    </div>`).join('');
  }catch(e){el.innerHTML='<div class="empty">Error loading photos</div>';}
}

// ---- MY HOURS (employee/lead) ----
async function loadMyHours(){
  const sumEl=document.getElementById('myHoursSummary');
  const el=document.getElementById('myHoursContent');
  if(!el)return;
  el.innerHTML='<div class="empty"><div class="ei">⏳</div>Loading...</div>';

  const month=document.getElementById('myHoursMonth')?.value||new Date().toISOString().slice(0,7);
  const mtdStart=month+'-01';
  const mtdEnd=month+'-31';

  try{
    const snap=await window.F.getDocs(window.F.query(window.F.collection(window.db,'dailyReports'),window.F.orderBy('timestamp','desc'),window.F.limit(200)));
    const myShifts=snap.docs.map(d=>({id:d.id,...d.data()})).filter(r=>r.employee===CU.name&&r.date>=mtdStart&&r.date<=mtdEnd);

    const totalHours=myShifts.reduce((s,r)=>s+(parseFloat(r.hoursWorked)||0),0);

    if(sumEl){
      sumEl.innerHTML=`<div class="stat-grid" style="margin-bottom:12px">
        <div class="stat-card"><div class="stat-label">Total hours</div><div class="stat-val" style="color:var(--blue)">${totalHours.toFixed(1)}</div><div class="stat-sub">${new Date(month+'-01').toLocaleDateString('en-US',{month:'long',year:'numeric'})}</div></div>
        <div class="stat-card"><div class="stat-label">Shifts worked</div><div class="stat-val">${myShifts.length}</div><div class="stat-sub">this month</div></div>
      </div>`;
    }

    if(!myShifts.length){el.innerHTML='<div class="empty"><div class="ei">⏱</div>No shifts recorded this month</div>';return;}

    const sorted=myShifts.sort((a,b)=>b.date.localeCompare(a.date));
    el.innerHTML='<div class="card">'+sorted.map(r=>`<div class="hours-row">
      <div>
        <div style="font-weight:500">${new Date(r.date+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'})}</div>
        <div style="font-size:11px;color:var(--text3)">${r.shift||''} ${r.startTime&&r.endTime?'· '+r.startTime+' – '+r.endTime:''} ${r.shiftComment?'· "'+r.shiftComment+'"':''}</div>
      </div>
      <div style="font-weight:600;color:var(--blue);flex-shrink:0">${r.hoursWorked?r.hoursWorked.toFixed(1)+' hrs':'—'}</div>
    </div>`).join('')+'</div>';
  }catch(e){el.innerHTML='<div class="empty">Error loading hours</div>';}
}

