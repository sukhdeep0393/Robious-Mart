function calcHours(){
  const s=document.getElementById('d-start').value;
  const e=document.getElementById('d-end').value;
  if(!s||!e){document.getElementById('d-hours').value='';return;}
  let [sh,sm]=s.split(':').map(Number);
  let [eh,em]=e.split(':').map(Number);
  let totalMins=(eh*60+em)-(sh*60+sm);
  if(totalMins<0)totalMins+=24*60; // overnight shift
  const hrs=Math.floor(totalMins/60);
  const mins=totalMins%60;
  const decimalHrs=parseFloat((totalMins/60).toFixed(2));
  // Show as "9h 30min (9.50 hrs)" so both formats are clear
  document.getElementById('d-hours').value=hrs+'h '+(mins>0?mins+'min':'')+'  ('+decimalHrs+' hrs)';
  return decimalHrs;
}

