<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Robious Mart — Ops</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Robious Mart">
<style>
  :root{--blue:#1a5ca8;--blue-dark:#154d91;--blue-light:#e8f0fb;--green:#3B6D11;--green-light:#EAF3DE;--red:#A32D2D;--red-light:#FCEBEB;--amber:#854F0B;--amber-light:#FAEEDA;--border:#e2e2de;--text:#1a1a18;--text2:#6b6b67;--text3:#9b9b97;--bg:#ffffff;--bg2:#f8f8f6;--r:10px;--rl:14px;}
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg2);color:var(--text);font-size:15px;min-height:100vh;}
  input,select,textarea{font-family:inherit;font-size:15px;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;width:100%;outline:none;-webkit-appearance:none;}
  input:focus,select:focus,textarea:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(26,92,168,.12);}
  button{font-family:inherit;cursor:pointer;}
  label{font-size:13px;color:var(--text2);display:block;margin-bottom:5px;font-weight:500;}
  /* LOGIN */
  #loginScreen{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:30px 24px;}
  .login-logo{font-size:28px;font-weight:800;margin-bottom:6px;}.login-logo span{color:var(--blue);}
  .login-sub{font-size:13px;color:var(--text3);margin-bottom:32px;}
  .lcard{background:var(--bg);border:1px solid var(--border);border-radius:var(--rl);padding:24px;width:100%;max-width:360px;}
  .ltabs{display:flex;gap:8px;margin-bottom:20px;}
  .ltab{flex:1;padding:9px;border-radius:var(--r);font-size:13px;font-weight:600;border:1px solid var(--border);background:var(--bg2);color:var(--text2);}
  .ltab.active{background:var(--blue);color:#fff;border-color:var(--blue);}
  .pin-dots{display:flex;justify-content:center;gap:12px;margin-bottom:20px;}
  .pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--border);background:var(--bg2);transition:background .15s;}
  .pin-dot.filled{background:var(--blue);border-color:var(--blue);}
  .pin-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
  .pk{padding:16px;border-radius:var(--r);font-size:20px;font-weight:600;border:1px solid var(--border);background:var(--bg);color:var(--text);}
  .pk:active{background:var(--bg2);transform:scale(.96);}
  .pk.del{font-size:16px;color:var(--text2);}
  .pk.blank{border:none;background:none;cursor:default;}
  .lerr{color:var(--red);font-size:13px;text-align:center;min-height:20px;margin-bottom:10px;}
  .btn-login{width:100%;padding:13px;background:var(--blue);color:#fff;border:none;border-radius:var(--r);font-size:15px;font-weight:600;}
  /* APP */
  #appShell{display:none;}
  .header{background:var(--bg);border-bottom:1px solid var(--border);padding:13px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
  .logo{font-size:17px;font-weight:700;}.logo span{color:var(--blue);}
  .ubadge{font-size:12px;color:var(--text2);background:var(--bg2);padding:4px 10px;border-radius:20px;border:1px solid var(--border);}
  .lout{font-size:12px;color:var(--text3);background:none;border:none;padding:4px 8px;}
  .alert-banner{background:var(--red-light);border-bottom:1px solid #f7c1c1;padding:10px 16px;font-size:13px;color:var(--red);font-weight:500;}
  .tab-bar{background:var(--bg);border-bottom:1px solid var(--border);padding:0 8px;display:flex;overflow-x:auto;scrollbar-width:none;}
  .tab-bar::-webkit-scrollbar{display:none;}
  .tab{padding:13px 12px 11px;font-size:13px;font-weight:500;color:var(--text2);border:none;background:none;border-bottom:2.5px solid transparent;white-space:nowrap;}
  .tab.active{color:var(--blue);border-bottom-color:var(--blue);}
  .page{display:none;padding:16px 16px 100px;max-width:600px;margin:0 auto;}
  .page.active{display:block;}
  .card{background:var(--bg);border:1px solid var(--border);border-radius:var(--rl);padding:16px;margin-bottom:12px;}
  .ct{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px;}
  .g2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  .g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
  .btn{display:block;width:100%;padding:13px;border-radius:var(--r);font-size:15px;font-weight:600;border:none;text-align:center;}
  .btn:active{transform:scale(.98);opacity:.9;}
  .bprimary{background:var(--blue);color:#fff;}
  .bsecondary{background:var(--bg2);color:var(--text);border:1px solid var(--border);}
  .bsm{font-size:12px;padding:5px 12px;border-radius:20px;background:var(--bg2);color:var(--text2);border:1px solid var(--border);display:inline-block;width:auto;}
  .bdsm{font-size:12px;padding:5px 12px;border-radius:20px;background:var(--red-light);color:var(--red);border:1px solid #f7c1c1;display:inline-block;width:auto;}
  .badge{display:inline-flex;align-items:center;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;}
  .bred{background:var(--red-light);color:var(--red);}
  .bamb{background:var(--amber-light);color:var(--amber);}
  .bgrn{background:var(--green-light);color:var(--green);}
  .bblu{background:var(--blue-light);color:var(--blue);}
  .metric{background:var(--bg2);border-radius:var(--r);padding:12px;}
  .mlab{font-size:11px;color:var(--text2);margin-bottom:4px;font-weight:500;}
  .mval{font-size:20px;font-weight:700;}
  .mok{background:var(--green-light);color:var(--green);border-radius:8px;padding:8px 12px;font-size:12px;font-weight:500;margin-top:8px;}
  .merr{background:var(--red-light);color:var(--red);border-radius:8px;padding:8px 12px;font-size:12px;font-weight:500;margin-top:8px;}
  .uzone{border:2px dashed var(--border);border-radius:var(--rl);padding:28px 16px;text-align:center;cursor:pointer;}
  .uzone:active{background:var(--bg2);}
  .fbar{margin-bottom:10px;}
  .fbar-h{display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;}
  .fbar-t{background:var(--border);border-radius:4px;height:8px;}
  .fbar-f{height:100%;border-radius:4px;}
  .sh{display:grid;grid-template-columns:1fr 55px 75px 50px;gap:6px;font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;padding:0 2px 8px;border-bottom:1px solid var(--border);margin-bottom:8px;}
  .sr{display:grid;grid-template-columns:1fr 55px 75px 50px;gap:6px;align-items:center;margin-bottom:8px;}
  .sn{font-size:13px;line-height:1.3;}
  .sp{font-size:13px;color:var(--text2);}
  .crow{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border);gap:8px;}
  .crow:last-child{border-bottom:none;}
  .irow{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);gap:8px;}
  .irow:last-child{border-bottom:none;}
  .aibox{background:var(--bg2);border-radius:var(--r);padding:14px;font-size:13px;line-height:1.7;color:var(--text2);white-space:pre-wrap;min-height:60px;}
  .litem{padding:12px 0;border-bottom:1px solid var(--border);}
  .litem:last-child{border-bottom:none;}
  .ltitle{font-size:13px;font-weight:500;margin-bottom:3px;display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
  .lmeta{font-size:11px;color:var(--text3);margin-bottom:3px;}
  .ldet{font-size:12px;color:var(--text2);}
  .empty{text-align:center;padding:28px 16px;color:var(--text3);font-size:13px;}
  .ei{font-size:28px;margin-bottom:6px;}
  .spinner{display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px;}
  @keyframes spin{to{transform:rotate(360deg)}}
  .toast{position:fixed;bottom:88px;left:50%;transform:translateX(-50%);background:#1a1a18;color:#fff;padding:10px 18px;border-radius:20px;font-size:13px;font-weight:500;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;}
  .toast.show{opacity:1;}
  .sh2{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
  .short-over-box{border-radius:8px;padding:10px 12px;font-size:13px;font-weight:500;margin-top:8px;}
  .short-box{background:var(--red-light);color:var(--red);}
  .over-box{background:var(--green-light);color:var(--green);}
  .even-box{background:var(--blue-light);color:var(--blue);}
  .auto-scanning{background:var(--amber-light);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--amber);margin-top:10px;display:flex;align-items:center;gap:8px;}
  /* DASHBOARD */
  .dash-greeting{font-size:20px;font-weight:700;margin-bottom:2px;}
  .dash-date{font-size:13px;color:var(--text3);margin-bottom:16px;}
  .stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
  .stat-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--rl);padding:14px;}
  .stat-label{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px;}
  .stat-val{font-size:22px;font-weight:700;margin-bottom:2px;}
  .stat-sub{font-size:11px;color:var(--text3);}
  .stat-change{font-size:12px;font-weight:600;margin-top:4px;}
  .ch-up{color:var(--green);}
  .ch-dn{color:var(--red);}
  .ch-neu{color:var(--text3);}
  .dash-section{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin:18px 0 10px;}
  .emp-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px;}
  .emp-row:last-child{border-bottom:none;}
  .emp-name{font-weight:500;}
  .emp-detail{font-size:12px;color:var(--text2);margin-top:2px;}
  .mtd-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;}
  .mtd-row:last-child{border-bottom:none;}
  .alert-item{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);font-size:13px;}
  .alert-item:last-child{border-bottom:none;}
  .loading-dash{text-align:center;padding:40px 20px;color:var(--text3);font-size:13px;}

  /* EMPLOYEES TAB */
  .emp-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--rl);padding:16px;margin-bottom:12px;}
  .emp-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
  .emp-avatar{width:38px;height:38px;border-radius:50%;background:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:var(--blue);flex-shrink:0;}
  .hours-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px;}
  .hours-row:last-child{border-bottom:none;}
  .fuel-photo-thumb{width:100%;border-radius:var(--r);max-height:180px;object-fit:cover;cursor:pointer;margin-top:8px;}
  .filter-bar{display:flex;gap:8px;margin-bottom:12px;}
  .filter-bar input,.filter-bar select{flex:1;}

</style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-logo">Robious<span> Mart</span></div>
  <div class="login-sub">Operations Platform</div>
  <div class="lcard">
    <div class="ltabs">
      <button class="ltab active" onclick="switchLTab('op',this)">Operator</button>
      <button class="ltab" onclick="switchLTab('emp',this)">Employee</button>
    </div>
    <div id="opLogin">
      <div style="margin-bottom:10px"><label>Email</label><input type="email" id="opEmail" placeholder="your@email.com" /></div>
      <div style="margin-bottom:14px"><label>Password</label><input type="password" id="opPass" placeholder="Password" onkeydown="if(event.key==='Enter')doOpLogin()" /></div>
      <div class="lerr" id="opErr"></div>
      <button class="btn-login" onclick="doOpLogin()">Sign in</button>
    </div>
    <div id="empLogin" style="display:none">
      <div style="margin-bottom:12px"><label>Your name</label><input type="text" id="empName" placeholder="First name" /></div>
      <div class="pin-dots"><div class="pin-dot" id="pd0"></div><div class="pin-dot" id="pd1"></div><div class="pin-dot" id="pd2"></div><div class="pin-dot" id="pd3"></div></div>
      <div class="lerr" id="pinErr"></div>
      <div class="pin-pad">
        <button class="pk" onclick="pk('1')">1</button><button class="pk" onclick="pk('2')">2</button><button class="pk" onclick="pk('3')">3</button>
        <button class="pk" onclick="pk('4')">4</button><button class="pk" onclick="pk('5')">5</button><button class="pk" onclick="pk('6')">6</button>
        <button class="pk" onclick="pk('7')">7</button><button class="pk" onclick="pk('8')">8</button><button class="pk" onclick="pk('9')">9</button>
        <button class="pk blank" disabled></button><button class="pk" onclick="pk('0')">0</button><button class="pk del" onclick="pdel()">⌫</button>
      </div>
    </div>
  </div>
</div>

<!-- APP -->
<div id="appShell">
  <div class="header">
    <div class="logo">Robious<span> Mart</span></div>
    <div style="display:flex;align-items:center;gap:8px">
      <span class="ubadge" id="uBadge"></span>
      <button class="lout" onclick="doLogout()">Sign out</button>
    </div>
  </div>
  <div class="alert-banner" id="alertBanner" style="display:none"></div>
  <div class="tab-bar" id="tabBar"></div>

  <!-- DASHBOARD (operator only) -->
  <div class="page" id="page-dashboard">
    <div id="dashContent"><div class="loading-dash"><div style="font-size:28px;margin-bottom:8px">⏳</div>Loading your dashboard...</div></div>
  </div>

  <!-- DAILY -->
  <div class="page" id="page-daily">
    <div class="card"><div class="ct">Shift info</div>
      <div class="g3" style="margin-bottom:10px">
        <div><label>Employee</label><input id="d-emp" readonly style="background:var(--bg2)" /></div>
        <div><label>Date</label><input type="date" id="d-date" /></div>
        <div><label>Shift</label><select id="d-shift"><option value="morning">Morning</option><option value="afternoon">Afternoon</option><option value="night">Night</option></select></div>
      </div>
      <div class="g3" style="margin-bottom:10px">
        <div><label>Start time</label><input type="time" id="d-start" /></div>
        <div><label>End time</label><input type="time" id="d-end" oninput="calcHours()" /></div>
        <div><label>Hours worked</label><input id="d-hours" readonly placeholder="Auto" style="background:var(--bg2);font-weight:600;color:var(--blue)" /></div>
      </div>
      <div><label>Shift comment (optional)</label><input id="d-comment" placeholder="e.g. Busy morning, delivery arrived..." /></div>
    </div>
    <div class="card">
      <div class="ct">C-store sales</div>
      <div class="g3" style="margin-bottom:10px">
        <div><label>Total sales ($)</label><input type="number" id="d-tot" placeholder="0.00" oninput="chkMatch()" /></div>
        <div><label>Cash ($)</label><input type="number" id="d-cash" placeholder="0.00" oninput="chkMatch()" /></div>
        <div><label>Credit ($)</label><input type="number" id="d-cred" placeholder="0.00" oninput="chkMatch()" /></div>
      </div>
      <div id="matchInd"></div>
      <div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--border)">
        <div class="ct" style="margin-bottom:10px">Cash drawer — short or over</div>
        <div class="g2" style="margin-bottom:8px">
          <div><label>Expected cash ($)</label><input type="number" id="d-expected" placeholder="0.00" oninput="calcShortOver()" /></div>
          <div><label>Actual counted ($)</label><input type="number" id="d-actual" placeholder="0.00" oninput="calcShortOver()" /></div>
        </div>
        <div id="shortOverResult"></div>
      </div>
    </div>
    <div class="card"><div class="ct">Fuel sold (gallons)</div>
      <div class="g3">
        <div><label>Regular</label><input type="number" id="d-reg" placeholder="0.0" /></div>
        <div><label>Premium</label><input type="number" id="d-prem" placeholder="0.0" /></div>
        <div><label>Diesel</label><input type="number" id="d-dies" placeholder="0.0" /></div>
      </div>
    </div>
    <div class="card"><div class="ct">Lottery</div>
      <div class="g2" style="margin-bottom:10px">
        <div><label>Lottery total ($)</label><input type="number" id="d-ltot" placeholder="0.00" oninput="updLot()" /></div>
        <div><label>Lottery payout ($)</label><input type="number" id="d-lpay" placeholder="0.00" oninput="updLot()" /></div>
      </div>
      <div id="lotNet"></div>
    </div>
    <div class="card"><div class="ct">Incidents & notes</div>
      <div style="margin-bottom:10px"><label>Incidents / issues</label><textarea id="d-inc" rows="3" placeholder="Problems, equipment issues, complaints..."></textarea></div>
      <div><label>Notes for next shift</label><textarea id="d-notes" rows="2" placeholder="Pass-along notes..."></textarea></div>
    </div>
    <div class="card">
      <div class="ct">End-of-shift photos</div>
      <div style="background:var(--blue-light);border-radius:8px;padding:10px 12px;margin-bottom:12px;font-size:12px;color:var(--blue)">
        Take photos of your register tape, cash drawer, or any receipts. Claude will read them and fill in the numbers automatically.
      </div>
      <div class="uzone" onclick="document.getElementById('shiftPhotos').click()" style="padding:20px">
        <div style="font-size:28px;margin-bottom:6px">📸</div>
        <div style="font-size:14px;color:var(--text2)" id="shiftPhotoLabel">Tap to add photos (optional)</div>
        <div style="font-size:12px;color:var(--text3);margin-top:4px">Register tape, cash drawer, POS screen</div>
      </div>
      <input type="file" id="shiftPhotos" accept="image/*" multiple style="display:none" onchange="handleShiftPhotos(this)" />
      <div id="shiftPhotoScanMsg" style="display:none" class="auto-scanning"><span class="spinner" style="border-top-color:var(--amber)"></span>Claude is reading your photos and filling in numbers...</div>
    </div>
    <button class="btn bprimary" id="dailyBtn" onclick="subDaily()">Submit shift report</button>
  </div>

  <!-- FUEL -->
  <div class="page" id="page-fuel">
    <div class="card"><div class="ct">Upload fuel printout</div>
      <div class="uzone" onclick="document.getElementById('fuelPic').click()">
        <div id="fuelPrev"><div style="font-size:32px;margin-bottom:8px">📷</div><div style="font-size:14px;color:var(--text2)">Tap to photo or upload</div><div style="font-size:12px;color:var(--text3);margin-top:4px">Morning fuel inventory printout</div></div>
      </div>
      <input type="file" id="fuelPic" accept="image/*" style="display:none" onchange="prvFuel(this)" />
    </div>
    <div class="card"><div class="ct">Fuel report date & employee</div>
      <div class="g2">
        <div><label>Date</label><input type="date" id="f-date" /></div>
        <div><label>Employee</label><input id="f-emp" readonly style="background:var(--bg2)" /></div>
      </div>
    </div>
    <div class="card"><div class="ct">Manual entry (gallons in tank)</div>
      <div class="g3" style="margin-bottom:14px">
        <div><label>Regular</label><input type="number" id="f-reg" placeholder="gal" oninput="updFBars()" /></div>
        <div><label>Premium</label><input type="number" id="f-prem" placeholder="gal" oninput="updFBars()" /></div>
        <div><label>Diesel</label><input type="number" id="f-dies" placeholder="gal" oninput="updFBars()" /></div>
      </div>
      <div id="fuelBars"></div>
    </div>
    <button class="btn bprimary" onclick="subFuel()">Save fuel report</button>
  </div>

  <!-- SCRATCH-OFFS -->
  <div class="page" id="page-scratch">
    <div class="card"><div class="ct">Shift info</div>
      <div class="g2">
        <div><label>Employee</label><input id="s-emp" readonly style="background:var(--bg2)" /></div>
        <div><label>Reporting at</label><select id="s-type" onchange="document.getElementById('scrBtn').textContent=this.value==='start'?'Save opening count':'Save closing count'"><option value="start">Start of shift</option><option value="end">End of shift</option></select></div>
      </div>
    </div>
    <div class="card" id="mgmtCard" style="display:none">
      <div class="sh2"><div class="ct" style="margin:0">Manage scratch-off games</div><button class="bsm" onclick="togAddGame()">+ Add game</button></div>
      <div id="addGameForm" style="display:none;background:var(--bg2);border-radius:var(--r);padding:12px;margin-bottom:12px">
        <div class="g2" style="margin-bottom:8px">
          <div><label>Game name</label><input id="gname" placeholder="e.g. $1 Lucky Stars" /></div>
          <div><label>Ticket price ($)</label><input type="number" id="gprice" placeholder="1" min="1" max="30" /></div>
        </div>
        <div style="margin-bottom:8px"><label>Game # (1–33)</label><input type="number" id="gnum" placeholder="e.g. 7" min="1" max="33" /></div>
        <button class="btn bprimary" style="padding:10px;font-size:13px" onclick="addGame()">Add game</button>
      </div>
      <div id="gmList"></div>
    </div>
    <div class="card">
      <div style="background:var(--amber-light);border-radius:8px;padding:10px 12px;margin-bottom:14px;font-size:12px;color:var(--amber)">Count tickets <strong>remaining in dispenser</strong> for each active game</div>
      <div class="sh"><div>Game</div><div>Price</div><div>Count</div><div></div></div>
      <div id="scrRows"><div class="empty"><div class="ei">🎟</div>No games added yet</div></div>
