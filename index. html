async function handleShiftPhotos(input){
  if(!input.files.length) return;
  const label=document.getElementById('shiftPhotoLabel');
  const msg=document.getElementById('shiftPhotoScanMsg');
  label.textContent=`${input.files.length} photo${input.files.length>1?'s':''} selected — scanning...`;
  msg.style.display='flex';
  try{
    const imgs=[];
    for(const file of input.files){
      const b64=await new Promise(res=>{const r=new FileReader();r.onload=()=>res(r.result.split(',')[1]);r.readAsDataURL(file);});
      imgs.push({type:'image',source:{type:'base64',media_type:file.type,data:b64}});
    }
    imgs.push({type:'text',text:'These are end-of-shift photos from a convenience store (Robious Mart, Virginia). Please read all visible numbers and extract: 1) Total sales if visible, 2) Cash sales amount, 3) Credit/card sales amount, 4) Any lottery totals or payouts, 5) Any fuel gallon amounts. Return ONLY a JSON object like: {"totalSales":0,"cashSales":0,"creditSales":0,"lotteryTotal":0,"lotteryPayout":0,"regularGal":0,"premiumGal":0,"dieselGal":0,"notes":"any other relevant info seen"}. If a value is not visible return 0.'});
    const resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:500,messages:[{role:'user',content:imgs}]})});
    const data=await resp.json();
    const raw=data.content?.map(c=>c.text||'').join('')||'{}';
    const clean=raw.replace(/```json|```/g,'').trim();
    const vals=JSON.parse(clean);
    if(vals.totalSales) document.getElementById('d-tot').value=vals.totalSales;
    if(vals.cashSales) document.getElementById('d-cash').value=vals.cashSales;
    if(vals.creditSales) document.getElementById('d-cred').value=vals.creditSales;
    if(vals.lotteryTotal) document.getElementById('d-ltot').value=vals.lotteryTotal;
